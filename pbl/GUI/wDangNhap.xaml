<Window x:Class="PBL3.GUI.wDangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.Background>
                <ImageBrush ImageSource="/Images/bg_login.png" Stretch="UniformToFill" AlignmentX="Left"/>
            </Grid.Background>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.0"/>
                        <GradientStop Color="#E6000000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel VerticalAlignment="Bottom" Margin="40,40,40,60">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="TTN Milk Tea" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Mỗi ngụm trà," Foreground="White" FontSize="42" FontWeight="Bold"/>
                <TextBlock Text="Một niềm vui." Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,0,0,15"/>
                <TextBlock Text="Chào mừng bạn quay trở lại. Đăng nhập để nhận ưu đãi đặc biệt và tích điểm thưởng ngay hôm nay." Foreground="#D0D0D0" FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#FDFDFD">
            <StackPanel Width="420" VerticalAlignment="Center">
                <TextBlock Text="Đăng nhập" FontSize="32" FontWeight="Heavy" Foreground="#1A1A1A" Margin="0,0,0,8"/>
                <TextBlock Text="Vui lòng nhập thông tin tài khoản của bạn" FontSize="14" Foreground="#7A7A7A" Margin="0,0,0,35"/>

                <TextBlock Text="Số điện thoại" FontSize="13" FontWeight="SemiBold" Foreground="#4A4A4A" Margin="0,0,0,8"/>
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Height="50" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox x:Name="txtPhoneNumber" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="15" Foreground="#1A1A1A" Padding="0,0,15,0"/>
                    </Grid>
                </Border>

                <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="SemiBold" Foreground="#4A4A4A" Margin="0,0,0,8"/>
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Height="50" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <PasswordBox x:Name="txtPassword" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="15" Foreground="#1A1A1A"/>
                        <TextBox x:Name="txtPasswordVisible" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="15" Foreground="#1A1A1A" Visibility="Collapsed"/>

                        <TextBlock x:Name="btnTogglePassword" Grid.Column="2" Text="&#xE18B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="btnTogglePassword_Click"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                </Grid>

                <Button x:Name="btnDangNhap" Click="btnDangNhap_Click" Height="50" Cursor="Hand" Margin="0,0,0,30">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#F28500" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#E07700"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Đăng nhập" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </Button>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Fill="#E0E0E0" Height="1" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="2" Fill="#E0E0E0" Height="1" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Chưa có tài khoản? " Foreground="#7A7A7A" FontSize="14"/>
                    <TextBlock x:Name="lblDangKy" Text="Đăng ký ngay" Foreground="#F28500" FontSize="14" FontWeight="SemiBold" Cursor="Hand" MouseLeftButtonDown="lblDangKy_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
        </Grid>
    </Grid>
</Window>