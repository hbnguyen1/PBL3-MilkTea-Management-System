<Window x:Class="PBL3.GUI.wTrangChu_NhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý - TTN MilkTea" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A1A1A">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="30,30,0,40">
                    <TextBlock Text="TTN STAFF" FontSize="20" FontWeight="Heavy" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="MENU QUẢN LÝ" Foreground="#7A7A7A" FontSize="12" FontWeight="SemiBold" Margin="30,0,0,15"/>

                <StackPanel Margin="15,0">
                    <RadioButton Style="{DynamicResource MenuButtonStyle}" Content="Tổng quan" Tag="&#xE80F;" IsChecked="True"/>

                    <RadioButton Style="{DynamicResource MenuButtonStyle}" Content="Quản lý Đơn hàng" Tag="&#xE7BF;" Checked="btnQuanLyDonHang_Checked"/>

                    <RadioButton Style="{DynamicResource MenuButtonStyle}" Content="Quản lý Sản phẩm" Tag="&#xE74C;" Checked="btnQuanLyMon_Checked"/>

                    <RadioButton Style="{DynamicResource MenuButtonStyle}" Content="Kho nguyên liệu" Tag="&#xE7B8;" Checked="btnMenuKho_Checked"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,0">
                <Grid>
                    <TextBlock Text="Chào mừng quay trở lại, Nhân viên!" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Đăng xuất" Foreground="#F28500" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0" Cursor="Hand" MouseLeftButtonDown="lblDangXuat_Click"/>
                        <Border Background="#F5F5F5" Width="40" Height="40" CornerRadius="20">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1A1A1A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="30" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <ContentControl x:Name="MainContent" />
            </Border>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#F28500"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>