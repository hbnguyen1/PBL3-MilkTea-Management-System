<Window x:Class="PBL3.GUI.wThietLapMon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thiết lập Sản Phẩm" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F6F8"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="1. THÔNG TIN CHUNG" FontWeight="Bold" Foreground="#F28500" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tên món ăn:" Margin="0,0,0,5" Foreground="#7A7A7A"/>
                        <TextBox x:Name="txtTenMon" Height="35" Padding="5,0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Danh mục:" Margin="0,0,0,5" Foreground="#7A7A7A"/>
                        <ComboBox x:Name="cmbLoai" Height="35" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Milk Tea" IsSelected="True"/>
                            <ComboBoxItem Content="Fruit Tea"/>
                            <ComboBoxItem Content="Món khác"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Giá bán gốc (Size M):" Margin="0,0,0,5" Foreground="#7A7A7A"/>
                        <TextBox x:Name="txtGiaBase" Height="35" Padding="5,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="2. CÔNG THỨC PHA CHẾ (Chuẩn Size M)" FontWeight="Bold" Foreground="#F28500" Margin="0,0,0,5"/>
                    <TextBlock Text="*Lưu ý: Hệ thống sẽ tự động tính tỷ lệ nguyên liệu cho Size L (+50%)" FontStyle="Italic" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="cmbNguyenLieu" Grid.Column="0" Height="35" VerticalContentAlignment="Center" DisplayMemberPath="igName" SelectedValuePath="igID"/>
                        <TextBox x:Name="txtDinhLuong" Grid.Column="2" Height="35" VerticalContentAlignment="Center" Padding="10,0"/>

                        <Button x:Name="btnThemNguyenLieu" Grid.Column="4" Content="Thêm vào CT" Width="100" Background="#E8F5E9" Foreground="#2E7D32" FontWeight="Bold" Cursor="Hand" Click="btnThemNguyenLieu_Click"/>
                    </Grid>
                </StackPanel>

                <DataGrid x:Name="dgCongThuc" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="#FAFAFA" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NL" Binding="{Binding ingredientID}" Width="60"/>
                        <DataGridTextColumn Header="Định lượng (Size M)" Binding="{Binding quantityNeeded}" Width="*"/>
                        <DataGridTemplateColumn Header="Xóa" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa" Tag="{Binding ingredientID}" Click="btnXoaNguyenLieuKhoiCT_Click" Foreground="Red" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <CheckBox x:Name="chkAvailable" Content="Sẵn sàng phục vụ khách" IsChecked="True" VerticalAlignment="Center" FontWeight="Bold"/>
            <Button x:Name="btnLuuThongTin" Content="LƯU TOÀN BỘ THÔNG TIN" Background="#1A1A1A" Foreground="White" FontWeight="Bold" Height="45" Width="220" HorizontalAlignment="Right" Cursor="Hand" Click="btnLuuThongTin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>