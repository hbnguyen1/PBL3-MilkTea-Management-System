<Window x:Class="PBL3.GUI.wNhapHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo Phiếu Nhập Hàng" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F5F6F8"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="6.5*"/>
        </Grid.ColumnDefinitions>

        <!-- BÊN TRÁI: FORM NHẬP LIỆU -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="Chi Tiết Hàng Nhập" FontSize="18" FontWeight="Heavy" Foreground="#1A1A1A" Margin="0,0,0,20"/>

                <TextBlock Text="Chọn nguyên liệu" Margin="0,0,0,6" Foreground="#4A4A4A" FontWeight="SemiBold"/>
                <ComboBox x:Name="cmbNguyenLieu" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="10,0" DisplayMemberPath="igName" SelectedValuePath="igID"/>

                <TextBlock Text="Số lượng nhập" Margin="0,0,0,6" Foreground="#4A4A4A" FontWeight="SemiBold"/>
                <!-- Đã tăng Margin bottom lên 25 để bù lại khoảng trống của ô Giá Nhập -->
                <TextBox x:Name="txtSoLuong" Height="40" Margin="0,0,0,25" VerticalContentAlignment="Center" Padding="10,0"/>

                <Button x:Name="btnThemVaoPhieu" Content="THÊM VÀO PHIẾU" Height="45" Background="#E8F5E9" Foreground="#2E7D32" FontWeight="Bold" Cursor="Hand" Click="btnThemVaoPhieu_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- BÊN PHẢI: CHI TIẾT PHIẾU NHẬP ĐANG TẠO -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Danh Sách Chuẩn Bị Nhập" FontSize="18" FontWeight="Heavy" Foreground="#1A1A1A" Margin="0,0,0,15"/>

                <DataGrid x:Name="dgChiTietNhap" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB" RowHeight="45">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nguyên Liệu" Binding="{Binding igName}" Width="*"/>
                        <DataGridTextColumn Header="Số Lượng" Binding="{Binding quantityAdded}" Width="80"/>
                        <!-- Vẫn giữ lại cột hiển thị giá mặc định cho nhân viên dễ theo dõi -->
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding importPrice, StringFormat='{}{0:N0} đ'}" Width="100" Foreground="#F28500" FontWeight="Bold"/>
                        <DataGridTemplateColumn Header="Xóa" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa" Tag="{Binding igId}" Click="btnXoaKhoiPhieu_Click" Foreground="Red" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="btnHoanTatNhap" Grid.Row="2" Content="XÁC NHẬN NHẬP KHO" Height="50" Background="#F28500" Foreground="White" FontWeight="Heavy" FontSize="15" Margin="0,15,0,0" Cursor="Hand" Click="btnHoanTatNhap_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>