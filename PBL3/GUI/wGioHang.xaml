<Window x:Class="PBL3.GUI.wGioHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giỏ Hàng" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Giỏ Hàng Của Bạn" FontSize="24" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icGioHang">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding TenMon}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding MoTa}" Foreground="#7A7A7A" FontSize="13" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding GiaTien}" Foreground="#F28500" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                                <TextBlock Text="&#xE107;" FontFamily="Segoe MDL2 Assets" Foreground="#FF4D4D" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" FontSize="16"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="20" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="-2" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <TextBlock Text="Tổng thanh toán:" FontSize="16" FontWeight="SemiBold" Foreground="#4A4A4A"/>
                    <TextBlock x:Name="lblTongTien" Text="0đ" FontSize="20" FontWeight="Heavy" Foreground="#F28500" HorizontalAlignment="Right"/>
                </Grid>

                <Button x:Name="btnThanhToan" Height="50" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#F28500" CornerRadius="10">
                                <TextBlock Text="Đặt Hàng" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>