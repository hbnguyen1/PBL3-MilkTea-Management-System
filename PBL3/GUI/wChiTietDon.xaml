<Window x:Class="PBL3.GUI.wChiTietDon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Đơn Hàng" Height="550" Width="450"
        WindowStartupLocation="CenterScreen" Background="#F5F6F8">
    <Border Background="White" Margin="20" Padding="20" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="PHIẾU PHA CHẾ" FontSize="22" FontWeight="Heavy" HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                <TextBlock x:Name="lblMaDon" Text="Đơn hàng: #TTN0000" FontSize="16" FontWeight="Bold" Foreground="#F28500" HorizontalAlignment="Center" Margin="0,5,0,0"/>

                <Path Stroke="#E0E0E0" StrokeThickness="1.5" StrokeDashArray="4,4" Data="M 0,0 L 400,0" Stretch="Fill" Margin="0,15,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icChiTiet">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SoLuong, StringFormat='{}{0}x'}" FontSize="16" FontWeight="Heavy" Foreground="#F28500"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TenMon}" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A"/>
                                    <TextBlock Text="{Binding Size, StringFormat='Size: {0}'}" FontSize="13" Foreground="#7A7A7A" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding GhiChu}" FontSize="13" FontStyle="Italic" Foreground="#FF4D4D" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <Path Stroke="#E0E0E0" StrokeThickness="1.5" StrokeDashArray="4,4" Data="M 0,0 L 400,0" Stretch="Fill" Margin="0,0,0,15"/>
                <Button x:Name="btnDuyet" Click="btnDuyet_Click" Height="45" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="#F28500" CornerRadius="8">
                                <TextBlock Text="HOÀN THÀNH PHA CHẾ" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#D97700"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>