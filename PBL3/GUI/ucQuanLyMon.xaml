<UserControl x:Class="PBL3.GUI.ucQuanLyMon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True" 
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             Background="#F5F6F8" FontFamily="Segoe UI">

    <Grid Margin="30">
        <Border Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.05" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Danh Mục Sản Phẩm" FontSize="24" FontWeight="Heavy" Foreground="#1A1A1A"/>
                        <TextBlock Text="Quản lý toàn bộ thực đơn và công thức pha chế." Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Click="btnThemMonMoi_Click" Cursor="Hand" Margin="0,0,15,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#4CAF50" CornerRadius="8" Padding="20,10">
                                        <TextBlock Text="+ THÊM MỚI" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Click="btnRefresh_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#F3F4F6" CornerRadius="8" Padding="15,10">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Foreground="#4A4A4A" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Làm mới" Foreground="#4A4A4A" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="dgMonAn" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                          RowHeight="55" CanUserAddRows="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding itemID}" Width="80"/>
                        <DataGridTextColumn Header="Tên Món" Binding="{Binding itemName}" Width="*"/>
                        <DataGridTextColumn Header="Loại" Binding="{Binding itemType}" Width="150"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding size}" Width="80"/>
                        <DataGridTextColumn Header="Giá Bán" Binding="{Binding price, StringFormat='{}{0:N0} đ'}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#F28500"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Trạng Thái" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding isAvailable}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="Bold" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="SẴN SÀNG"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding isAvailable}" Value="False">
                                                            <Setter Property="Text" Value="TẠM HẾT"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Thao tác" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="btnMoFormSua_Click" Tag="{Binding itemID}" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#FFF3E0" CornerRadius="6" Padding="12,6">
                                                    <TextBlock Text="Sửa món" Foreground="#E65100" FontWeight="Bold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>