<Window x:Class="PBL3.GUI.wHoaDon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hóa Đơn Thanh Toán" Height="750" Width="420"
        WindowStartupLocation="CenterScreen" Background="#F5F6F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="White" Margin="20,20,20,10" CornerRadius="16" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#F28500" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="TTN Milk Tea" FontSize="22" FontWeight="Heavy" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                    <TextBlock Text="Đại học Bách Khoa, Đà Nẵng" FontSize="13" Foreground="#7A7A7A" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="0833 584 225" FontSize="13" Foreground="#7A7A7A" HorizontalAlignment="Center" Margin="0,2,0,25"/>

                    <Grid Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="MÃ ĐƠN HÀNG" FontSize="11" Foreground="#A0A0A0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="lblMaDon" Text="#12345" FontSize="14" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,4,0,4"/>
                            <TextBlock x:Name="lblNgayGio" Text="24/05/2026 • 14:30" FontSize="12" Foreground="#7A7A7A"/>
                        </StackPanel>
                    </Grid>

                    <Path Stroke="#EBEBEB" StrokeThickness="1.5" StrokeDashArray="4,4" Data="M 0,0 L 400,0" Stretch="Fill" Margin="0,10,0,20"/>

                    <ItemsControl x:Name="icHoaDon">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SoLuong, StringFormat='{}{0}x'}" FontSize="15" FontWeight="Bold" Foreground="#F28500"/>

                                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding TenMon}" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                        <TextBlock Text="{Binding MoTa}" FontSize="12" Foreground="#7A7A7A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding ThanhTienStr}" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A" VerticalAlignment="Top"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Path Stroke="#EBEBEB" StrokeThickness="1.5" StrokeDashArray="4,4" Data="M 0,0 L 400,0" Stretch="Fill" Margin="0,5,0,20"/>

                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Tạm tính" FontSize="14" Foreground="#7A7A7A"/>
                        <TextBlock x:Name="lblTamTinh" Text="0đ" FontSize="14" Foreground="#7A7A7A" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Phí giao hàng" FontSize="14" Foreground="#7A7A7A"/>
                        <TextBlock Text="0đ" FontSize="14" Foreground="#7A7A7A" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,10,0,30">
                        <TextBlock Text="TỔNG CỘNG" FontSize="18" FontWeight="Heavy" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblTongTienHoaDon" Text="0đ" FontSize="20" FontWeight="Heavy" Foreground="#F28500" HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="QUÉT ĐỂ THANH TOÁN" FontSize="12" FontWeight="Bold" Foreground="#A0A0A0" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <Border Background="#FAFAFA" BorderBrush="#F0F0F0" BorderThickness="1" CornerRadius="16" Padding="15" Margin="30,0,30,30">
                        <StackPanel>
                            <Image Source="/Images/qrcode.png" Width="150" Height="150" Stretch="Uniform" Margin="0,0,0,12"/>
                            <TextBlock Text="MB Bank - TRINH NHAN TAM" FontSize="12" FontWeight="SemiBold" Foreground="#4A4A4A" HorizontalAlignment="Center"/>
                            <TextBlock Text="0833 584 225" FontSize="15" FontWeight="Bold" Foreground="#F28500" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>


                    <TextBlock Text="Cảm ơn quý khách!" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Hẹn gặp lại bạn lần sau nhé!" FontSize="13" FontStyle="Italic" Foreground="#7A7A7A" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="1" Background="White" Padding="20,15" BorderBrush="#EBEBEB" BorderThickness="0,1,0,0">
            <Button Click="btnDong_Click" Height="48" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" CornerRadius="12">
                            <TextBlock Text="HOÀN TẤT GIAO DỊCH" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</Window>